# ── Core API Keys ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Visual Asset APIs ──────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
POLLINATIONS_API_KEY=optional_pollinations_key
FREEPIK_API_KEY=your_freepik_api_key

# ── NVIDIA NIM (technical topic routing) ──────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# ── Database & Auth ───────────────────────────────────────────────────────────
# Main DB for SkyNet presentations/logs
MONGODB_URI=your_mongodb_atlas_uri_here

# External Timesheet DB — Shared Authentication
TIMESHEET_MONGODB_URI=your_timesheet_mongodb_uri_here
TIMESHEET_DB_NAME=Timesheet-Application

JWT_SECRET=your_secure_random_jwt_secret_here

# ── Production Config ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
GROQ_MODEL=llama-3.3-70b-versatile
PPT_FONT=Calibri
PORT=8000
